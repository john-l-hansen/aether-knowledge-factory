{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KnowledgeUnit",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-_]+$" },
    "title": { "type": "string" },
    "type": { "type": "string", "enum": ["concept", "insight", "fact"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "last_updated": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" }
        },
        "required": ["id", "type"]
      }
    },
    "content": { "type": "string" }
  },
  "required": ["id", "title", "type", "tags", "confidence", "content"]
}
